# LLM Provider Configuration
# Copy this file to .env and adjust values as needed.
# Restart the Jupyter kernel after changes.
#
# Supported providers: "ollama" (default), "anthropic"
LLM_PROVIDER=ollama

# --- Ollama settings (used when LLM_PROVIDER=ollama) ---
# OLLAMA_MODEL=ministral-3:14b

# --- Anthropic via Hyperspace AI Local LLM Proxy (used when LLM_PROVIDER=anthropic) ---
# ANTHROPIC_MODEL=anthropic--claude-4.6-opus
# ANTHROPIC_BASE_URL=http://localhost:6655/anthropic/
# ANTHROPIC_API_KEY=your-hyperspace-token-here
